# --- DB ---
# 로컬(docker compose)에서 그대로 복사해 쓰면 됨.
# 배포 시(Neon/Supabase/RDS)에는 호스트만 교체.
DATABASE_URL="postgresql://tracker:tracker@localhost:5432/content_tracker?schema=public"
DIRECT_URL="postgresql://tracker:tracker@localhost:5432/content_tracker?schema=public"

# --- Naver Search API ---
# https://developers.naver.com/main/  → Application 등록 → "검색" API 사용 신청
NAVER_CLIENT_ID=""
NAVER_CLIENT_SECRET=""

# --- Anthropic ---
# https://console.anthropic.com
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-sonnet-4-6"

# --- Discord ---
# 채널 설정 > 연동 > 웹후크
DISCORD_WEBHOOK_URL=""

# --- SerpAPI (Google SEO 순위 측정) ---
# https://serpapi.com → Sign Up → Dashboard → Your Private API Key
# 무료 100회/월. 미설정 시 Google 측정은 자동 skip.
SERPAPI_KEY=""

# --- 자사 도메인 (SEO 순위 측정용) ---
OWN_DOMAIN="5010.tech"

# --- Cron 인증 (외부에서 트리거할 때 헤더 검사) ---
# 로컬에서는 비워둬도 통과
CRON_SECRET=""

# --- Basic Auth (운영팀 전용 접근) ---
# 둘 다 비우면 미들웨어 패스. 운영에선 반드시 둘 다 설정.
BASIC_AUTH_USER=""
BASIC_AUTH_PASSWORD=""
